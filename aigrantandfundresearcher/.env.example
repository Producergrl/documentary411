# Development-only environment variables.
# These values are bundled into the packaged app at build time.
# Never commit real values to version control.

# Google OAuth — register as Desktop app in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth — register as mobile/desktop app in Azure (public client)
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common

# Gumroad — product_permalink from your Gumroad dashboard
GUMROAD_PRODUCT_ID=

# Flask — use a random 32-char string in production build
FLASK_SECRET_KEY=change-me-before-build
